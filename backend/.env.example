# ── Creem API 密钥 ────────────────────────────────────
# 从 https://dashboard.creem.io/settings/api-keys 获取
CREEM_API_KEY=creem_test_xxxxxxxxxxxxxxxxxxxx

# Creem Webhook 签名密钥
# 在 Creem Dashboard → Developers → Webhooks 创建 endpoint 后获取
CREEM_WEBHOOK_SECRET=wh_xxxxxxxxxxxxxxxxxxxx

# Creem 产品 ID
# 在 Creem Dashboard → Products 创建产品后获取
CREEM_PRODUCT_ID=prod_xxxxxxxxxxxxxxxxxxxx

# 测试模式（true=测试环境, false=生产环境）
CREEM_TEST_MODE=true

# ── 服务器配置 ──────────────────────────────────────
# 前端地址（本地开发用 http://localhost:3000，生产环境用 Render 域名）
CLIENT_URL=https://paymvp.onrender.com

# 服务端口
PORT=3000
